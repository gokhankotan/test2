{
  "name": "muzakere-masasi",
  "version": "1.0.0",
  "description": "Habermas ideal konuşma durumu ve kamusal alan teorisine dayalı uzlaşı platformu",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "dev": "concurrently \"npm.cmd run dev:server\" \"npm.cmd run dev:client\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.395.0",
    "openai": "^4.52.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "prisma": "^5.16.1",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  },
  "allowScripts": {
    "bcrypt@5.1.1": true,
    "esbuild@0.21.5": true,
    "prisma@5.22.0": true,
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true
  }
}
